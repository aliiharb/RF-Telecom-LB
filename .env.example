# Use a hosted PostgreSQL URL from Neon, Supabase, Prisma Postgres, etc.
# Neon pooled example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rftelecomlb?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-secret"
JWT_SECRET="replace-with-a-long-random-secret-if-you-prefer-this-name"

ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@rftelecomlb.com"
# Local login can use ADMIN_PASSWORD. Production should use ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD="admin"
ADMIN_PASSWORD_HASH="$2b$12$SLhvAL45ZAgZRGrUrPwPn.oovz9NIooHL11rFP9GW4KWqTxeb7316"
ADMIN_ALI_EMAIL="ali@rftelecomlb.com"
ADMIN_ALI_PASSWORD="change-me-before-production"
ADMIN_ZAHRAA_EMAIL="zahraa@rftelecomlb.com"
ADMIN_ZAHRAA_PASSWORD="change-me-before-production"

WHATSAPP_ORDER_NUMBER="9611271999"
SITE_URL="https://rftelecomlb.com"

# Supabase server/admin values. Required by the admin catalog dashboard.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase browser/client compatibility values
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Logging (debug | info | warn | error)
LOG_LEVEL="warn"
VITE_LOG_LEVEL="warn"

# Store config used by the client-side checkout
VITE_STORE_WHATSAPP="9611271999"
VITE_STORE_NAME="RF Telecom LB"
NEXT_PUBLIC_STORE_WHATSAPP="9611271999"
NEXT_PUBLIC_STORE_NAME="RF Telecom LB"
